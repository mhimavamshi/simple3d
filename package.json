{
  "name": "simple3d",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "type-check:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "bundle:watch": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --format=esm --watch",
    "dev": "concurrently -n \"TS,ESBuild\" -c \"cyan,magenta\" \"npm:type-check:watch\" \"npm:bundle:watch\"",
    "type-check": "tsc --noEmit",
    "build:only": "esbuild src/index.ts --bundle --minify --outfile=dist/index.js --platform=node --format=esm",
    "build": "npm run type-check && npm run build:only"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
